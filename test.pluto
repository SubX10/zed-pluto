# This is a PLUTO test file

PROCEDURE check_temperature
  # Check if temperature is too high
  IF temperature > 50 THEN
    shutdown()
    LOG "temperature exceeded threshold"
  ELSE
    LOG "temperature normal"
  END
END

PROCEDURE activate_sequence
  IF signal > 0 THEN
    initiate()
  END
END

PROCEDURE monitor_pressure
  # CON block - execute if condition is true
  CON pressure > 100
    release_valve()
    LOG "pressure released"
  CONT

  # Continue normal operations
  LOG "pressure check complete"
END
